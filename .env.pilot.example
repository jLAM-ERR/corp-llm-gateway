# NOTE: proxy / air-gapped knobs do NOT go here. `.env.pilot` is an env_file
# (injected into the container), but compose reads `${...}` for build-args and the
# `environment:` block from your SHELL or a project-root `.env` — and that block
# would shadow any proxy value set here. Put the following in your shell or a
# project-root `.env` before `docker compose -f docker-compose.pilot.yml build/up`
# (all empty => open-internet build; see docs/ops/air-gapped.md):
#   HTTP_PROXY=http://proxy-host:3128
#   HTTPS_PROXY=http://proxy-host:3128
#   NO_PROXY=localhost,127.0.0.1,redis,postgres,corp-llm.corp.lan,<docker-subnet>
#   PIP_INDEX_URL=https://mirror-host/artifactory/api/pypi/<repo>/simple  # internal PyPI
#   PIP_TRUSTED_HOST=mirror-host          # if the mirror is plain-HTTP or off-proxy-CA
#   PIP_PROXY=http://pip-proxy-host:3128  # if pip uses a dedicated proxy node
#   EN_MODEL_URL=https://mirror-host/.../en_core_web_md-3.8.0-py3-none-any.whl
# Re-signing proxy? Also drop its root CA at crt/proxy-ca.crt (see crt/README.md).
CORP_LLM_ENDPOINT=https://corp-llm.corp.lan
CORP_LLM_AUTH_PROVIDER=noop
# Empty intentionally — corp LLM is currently auth-less. The litellm-config.yaml
# references this via os.environ/CORP_LLM_AUTH_TOKEN; declaring it here (even
# empty) avoids LiteLLM v1.85 startup errors when the env var is undefined.
CORP_LLM_AUTH_TOKEN=
# populated by scripts/pilot.sh seed-langfuse:
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
