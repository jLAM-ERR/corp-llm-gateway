# Copy to .env (git-ignored) and fill in real values.

# Any random string works — this becomes your X-Corp-Auth token for the
# `local-dev` team (dev-only seam, see config.example.toml
# "Solo/local dev auth seam"). Generate one: `openssl rand -hex 24`
CORP_LLM_DEV_TEAM_TOKEN=change-me-local-dev-token

# Gateway-side shared key(s) forwarded to Anthropic / OpenAI (see README.md
# "BYOK in local mode" — native anthropic/openai routing can't forward a
# per-developer key, so this is one key for this whole gateway instance).
# Set whichever provider(s) you actually use.
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
