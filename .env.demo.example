CORP_LLM_ENDPOINT=https://corp-llm.corp.lan
CORP_LLM_AUTH_PROVIDER=noop
# Empty intentionally — corp LLM is currently auth-less. The litellm-config.yaml
# references this via os.environ/CORP_LLM_AUTH_TOKEN; declaring it here (even
# empty) avoids LiteLLM v1.85 startup errors when the env var is undefined.
CORP_LLM_AUTH_TOKEN=
# populated by scripts/demo.sh seed-langfuse:
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
